    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.9",
    "tailwindcss": "^4.1.14",
    "tar": "^7.5.1"
  },
  "devDependencies": {
    "bcrypt": "^6.0.0",
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.7",
    "electron": "^29.1.4",
    "electronmon": "^2.0.2",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
