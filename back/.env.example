JWT_SECRET=replace_with_a_secure_secret
LEAKSHIELD_INVITE_BASE_URL=http://localhost:5173/invite/accept

# Option 1: use a named provider, for example Gmail
SMTP_SERVICE=gmail
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Option 2: use custom SMTP host settings instead of SMTP_SERVICE
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Asana remediation task integration
ASANA_ACCESS_TOKEN=your_asana_personal_access_token
ASANA_WORKSPACE_GID=your_asana_workspace_gid
ASANA_PROJECT_GID=your_asana_project_gid
REMEDIATION_TASK_DUE_DAYS=2

# Gmail OAuth2 for task notification emails
GOOGLE_OAUTH_USER=your-notifier@gmail.com
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token
# Optional short-lived token
GOOGLE_OAUTH_ACCESS_TOKEN=
